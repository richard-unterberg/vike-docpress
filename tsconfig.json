{
  "compilerOptions": {
    "strict": true,
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "types": ["node", "vite/client"],
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/components/*": ["components/*"],
      "@/pages/*": ["pages/*"],
      "@/assets/*": ["assets/*"],
      "@/server/*": ["server/*"],
      "@/docs/*": ["pages/(docs)/*"],
      "@/lib/*": ["lib/*"],
      "@/root/*": ["./*"]
    }
  },
  "exclude": ["dist", "lib/headings-legacy.ts"]
}
