{
  "name": "@unterberg/nivel",
  "version": "0.2.0",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/richard-unterberg/nivel.git",
    "directory": "packages/engine"
  },
  "homepage": "https://github.com/richard-unterberg/nivel",
  "bugs": {
    "url": "https://github.com/richard-unterberg/nivel/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "nivel": "bin/nivel.mjs"
  },
  "files": [
    "dist",
    "assets",
    "bin",
    "tailwind.css",
    "tailwind-sources.css"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./icons": {
      "types": "./dist/icons.d.ts",
      "import": "./dist/icons.js"
    },
    "./vike": {
      "types": "./dist/vike.d.ts",
      "import": "./dist/vike.js"
    },
    "./mdx": {
      "types": "./dist/mdx.d.ts",
      "import": "./dist/mdx.js"
    },
    "./mdx/code-blocks": {
      "types": "./dist/mdx/code-blocks.d.ts",
      "import": "./dist/mdx/code-blocks.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./runtime/client": {
      "types": "./dist/runtime/client.d.ts",
      "import": "./dist/runtime/client.js"
    },
    "./runtime/node": {
      "types": "./dist/runtime/node.d.ts",
      "import": "./dist/runtime/node.js"
    },
    "./tailwind": {
      "types": "./dist/tailwind.d.ts",
      "import": "./dist/tailwind.js"
    },
    "./daisyui-theme": {
      "types": "./dist/daisyui-theme.d.ts",
      "import": "./dist/daisyui-theme.js"
    },
    "./tailwind.css": "./tailwind.css",
    "./tailwind-sources.css": "./tailwind-sources.css"
  },
  "scripts": {
    "generate:icons": "node ./scripts/generate-icons-entry.mjs",
    "build": "pnpm generate:icons && tsup",
    "dev": "pnpm generate:icons && tsup --watch",
    "test": "pnpm generate:icons && node --import tsx --test tests/*.test.mjs tests/*.test.ts",
    "typecheck": "pnpm generate:icons && tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@brillout/shiki-transformers": "^4.0.2",
    "@classmatejs/react": "^0.2.1",
    "@mdx-js/rollup": "^3.1.1",
    "@shikijs/transformers": "^4.0.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.12",
    "daisyui": "^5.5.19",
    "detype": "^2.0.7",
    "estree-util-value-to-estree": "^3.5.0",
    "lucide-react": "^1.8.0",
    "mdast-util-mdx-jsx": "^3.2.0",
    "npm-to-yarn": "^3.0.1",
    "rehype-pretty-code": "^0.14.3",
    "remark-directive": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.0.2",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "unist-util-visit": "^5.1.0",
    "zustand": "^5.0.12"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "vike": ">=0.4.0",
    "vike-react": ">=0.6",
    "vite": ">=6"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vike": "^0.4.256",
    "vike-react": "^0.6.21",
    "vite": "^7.3.1"
  }
}
