{
  "name": "telefunc-docpress",
  "private": true,
  "scripts": {
    "generate:docs": "node scripts/generateDocsPages.mjs",
    "dev": "vike dev",
    "build": "vike build",
    "preview": "pnpm --filter @unterberg/universal-mdx-mods build && pnpm generate:docs && vike build && vike preview",
    "predev": "pnpm --filter @unterberg/universal-mdx-mods build && pnpm generate:docs",
    "prebuild": "pnpm --filter @unterberg/universal-mdx-mods build && pnpm generate:docs",
    "pretypecheck": "pnpm --filter @unterberg/universal-mdx-mods build && pnpm generate:docs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "typecheck:prepared": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@unterberg/universal-mdx-mods": "workspace:*",
    "@classmatejs/react": "^0.2.1",
    "lucide-react": "0.443.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "vike": "^0.4.255",
    "vike-react": "^0.6.21",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@mdx-js/rollup": "^3.1.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "daisyui": "^5.5.19",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^4.2.2",
    "vite": "^7.3.1"
  },
  "type": "module"
}
