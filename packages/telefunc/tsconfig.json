{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.cache/telefunc.tsbuildinfo",
    "types": ["node", "vite/client"],
    "baseUrl": ".",
    "paths": {
      "@/components/*": ["components/*"],
      "@/app-components/*": ["components/app/*"],
      "@/pages/*": ["pages/*"],
      "@/assets/*": ["assets/*"],
      "@/server/*": ["server/*"],
      "@/docs/*": ["pages/(docs)/*"],
      "@/lib/*": ["lib/*"],
      "@/root/*": ["./*"]
    }
  },
  "include": ["components", "lib", "pages", "scripts", "vite.config.ts"],
  "exclude": ["dist", "lib/headings-legacy.ts"],
  "references": [{ "path": "../universal-mdx-mods" }]
}
