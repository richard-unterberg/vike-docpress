{
  "name": "nivel",
  "private": true,
  "packageManager": "pnpm@10.28.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/richard-unterberg/nivel.git"
  },
  "homepage": "https://github.com/richard-unterberg/nivel",
  "bugs": {
    "url": "https://github.com/richard-unterberg/nivel/issues"
  },
  "scripts": {
    "preview": "pnpm --filter @unterberg/nivel build && pnpm --filter ./packages/consumer-test build && pnpm --filter ./packages/consumer-test exec vike preview",
    "dev": "pnpm --filter @unterberg/nivel build && pnpm --filter ./packages/consumer-test dev",
    "build": "pnpm --filter @unterberg/nivel build && pnpm --filter ./packages/consumer-test build",
    "typecheck": "pnpm --filter @unterberg/nivel build && pnpm --filter @unterberg/nivel typecheck && pnpm --filter ./packages/consumer-test typecheck",
    "lint": "biome lint --write .",
    "format": "biome format --write .",
    "knip": "pnpm --filter @unterberg/nivel build && pnpm --filter ./packages/consumer-test generate:docs && knip",
    "deploy:npm": "node ./scripts/deployNpm.mjs",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "knip": "^6.0.13",
    "lefthook": "^2.1.4",
    "typescript": "^6.0.2"
  }
}
