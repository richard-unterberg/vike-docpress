{
  "name": "nivel",
  "private": true,
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "repository": {
    "type": "git",
    "url": "https://github.com/richard-unterberg/nivel.git"
  },
  "homepage": "https://github.com/richard-unterberg/nivel",
  "bugs": {
    "url": "https://github.com/richard-unterberg/nivel/issues"
  },
  "scripts": {
    "preview": "pnpm --filter @unterberg/nivel build && pnpm --filter ./packages/consumer-dev build && pnpm --filter ./packages/consumer-dev exec vike preview",
    "dev": "pnpm --filter @unterberg/nivel build && pnpm -r --parallel --stream --filter @unterberg/nivel --filter ./packages/consumer-dev run dev",
    "dev:consumer": "pnpm --filter @unterberg/nivel build && pnpm --filter ./packages/consumer-dev dev",
    "build": "pnpm --filter @unterberg/nivel build && pnpm --filter ./packages/consumer-dev build",
    "purge:bunny": "node ./scripts/purgeBunnyPullZone.mjs",
    "typecheck": "pnpm --filter @unterberg/nivel build && pnpm --filter @unterberg/nivel typecheck && pnpm --filter ./packages/consumer-dev typecheck",
    "lint": "biome lint --write .",
    "format": "biome format --write .",
    "check:knip": "pnpm --filter @unterberg/nivel generate:icons && pnpm knip",
    "deploy:npm": "node ./scripts/deployNpm.mjs",
    "test:engine": "cd packages/engine && pnpm test",
    "prepare": "lefthook install",
    "verify": "pnpm format && pnpm run check:knip && pnpm run lint && pnpm run typecheck && pnpm run test:engine"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.11",
    "knip": "^6.0.13",
    "lefthook": "^2.1.5",
    "typescript": "^6.0.2"
  }
}
